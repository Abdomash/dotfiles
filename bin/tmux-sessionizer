#!/usr/bin/env bash

DIRS=(
    "$HOME"
    "$HOME/projects"
)

valid_dirs=()
for dir in "${DIRS[@]}"; do
    [[ -d "$dir" ]] && valid_dirs+=("$dir")
done

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$(find "${valid_dirs[@]}" -mindepth 1 -maxdepth 2 -type d | fzf)
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=${selected#"$HOME"/}
[[ "$selected_name" == "$selected" ]] && selected_name=${selected##*/}
selected_name=${selected_name//[\/.]/_}

if [[ -n $TMUX ]]; then
    tmux new-session -Ads "$selected_name" -c "$selected"
    tmux switch-client -t "$selected_name"
else
    exec tmux new-session -As "$selected_name" -c "$selected"
fi
